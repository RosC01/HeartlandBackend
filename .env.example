# Environment Variables — copy to .env and fill in values

DATABASE_URL="postgresql://heartland:heartland_secret@localhost:5432/heartlanddb"
JWT_SECRET="your-super-secret-jwt-key-change-this"
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Company info used in PDF invoices
COMPANY_NAME=
COMPANY_FROM_NAME=
COMPANY_FROM_CONTACTS=
# Optional: absolute path to PNG logo
LOGO_PATH=
# Payment terms lines separated by | (leave blank to auto-generate)
PAYMENT_TERMS="Heartland Field Services"
COMPANY_ADDRESS="123 Main Street"
COMPANY_CITY_STATE_ZIP="Springfield, IL 62701"
COMPANY_PHONE="(555) 555-5555"
COMPANY_EMAIL="billing@heartlandservices.com"
